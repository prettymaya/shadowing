.mp3","time_start":173.85,"time_end":179.29},{"position":65,"content":"That seems okay.","audio_url":"https://dailydictation.com/upload/ielts-listening/ielts-cambridge-7-test-2-part-1-2023-07-28-17-12-17/65.mp3","time_start":181.18,"time_end":182.51},{"position":66,"content":"It's quite a bit lower than I've been paying up to now.","audio_url":"https://dailydictation.com/upload/ielts-listening/ielts-cambridge-7-test-2-part-1-2023-07-28-17-12-17/66.mp3","time_start":182.51,"time_end":185.53},{"position":67,"content":"Great.","audio_url":"https://dailydictation.com/upload/ielts-listening/ielts-cambridge-7-test-2-part-1-2023-07-28-17-12-17/67.mp3","time_start":185.65,"time_end":186.58},{"position":68,"content":"So, would you like me to go ahead with that?","audio_url":"https://dailydictation.com/upload/ielts-listening/ielts-cambridge-7-test-2-part-1-2023-07-28-17-12-17/68.mp3","time_start":186.58,"time_end":189.39},{"position":69,"content":"Sure... why not?","audio_url":"https://dailydictation.com/upload/ielts-listening/ielts-cambridge-7-test-2-part-1-2023-07-28-17-12-17/69.mp3","time_start":189.39,"time_end":190.79},{"position":70,"content":"How would you like to pay?","audio_url":"https://dailydictation.com/upload/ielts-listening/ielts-cambridge-7-test-2-part-1-2023-07-28-17-12-17/70.mp3","time_start":191.15,"time_end":192.94}]}