.com/upload/english-conversations/46-how-about-a-drink-2022-03-07-21-20-21/7.mp3","time_start":12.04,"time_end":13.61},{"position":8,"content":"I will meet you there; I'm really looking forward to it!","audio_url":"https://dailydictation.com/upload/english-conversations/46-how-about-a-drink-2022-03-07-21-20-21/8.mp3","time_start":13.61,"time_end":16.38},{"position":9,"content":"Me too!","audio_url":"https://dailydictation.com/upload/english-conversations/46-how-about-a-drink-2022-03-07-21-20-21/9.mp3","time_start":16.38,"time_end":17.5}]}