ydictation.com/upload/toefl-listening/conversation-10-2023-02-03-22-22-56/51.mp3","time_start":133.45,"time_end":137.99},{"position":52,"content":"You know the author?","audio_url":"https://dailydictation.com/upload/toefl-listening/conversation-10-2023-02-03-22-22-56/52.mp3","time_start":138.31,"time_end":139.54},{"position":53,"content":"Uh... Jamison, or um, Jamiston. Why?","audio_url":"https://dailydictation.com/upload/toefl-listening/conversation-10-2023-02-03-22-22-56/53.mp3","time_start":139.84,"time_end":144.01},{"position":54,"content":"Because I can search it for you right now, Google Scholar.","audio_url":"https://dailydictation.com/upload/toefl-listening/conversation-10-2023-02-03-22-22-56/54.mp3","time_start":144.17,"time_end":147.79},{"position":55,"content":"Huh?","audio_url":"https://dailydictation.com/upload/toefl-listening/conversation-10-2023-02-03-22-22-56/55.mp3","time_start":147.97,"time_end":148.6},{"position":56,"content":"Yeah, haven't you heard?","audio_url":"https://dailydictation.com/upload/toefl-listening/conversation-10-2023-02-03-22-22-56/56.mp3","time_start":149.26,"time_end":150.75},{"position":57,"content":"University Libraries has linked up with Google's search of library holdings all over the world","audio_url":"https://dailydictation.com/upload/toefl-listening/conversation-10-2023-02-03-22-22-56/57.mp3","time_start":150.86,"time_end":156.89},{"position":58,"content":"Wow!","audio_url":"https://dailydictation.com/upload/toefl-listening/conversation-10-2023-02-03-22-22-56/58.mp3","time_start":157.04,"time_end":158.03},{"position":59,"content":"Just a sec.","audio_url":"https://dailydictation.com/upload/toefl-listening/conversation-10-2023-02-03-22-22-56/59.mp3","time_start":158.2,"time_end":159.08},{"position":60,"content":"Jamison?...","audio_url":"https://dailydictation.com/upload/toefl-listening/conversation-10-2023-02-03-22-22-56/60.mp3","time_start":159.47,"time_end":160.58},{"position":61,"content":"And the title's something a