/general-english/49-questions-and-answers-2019-03-29-10-19-31/22.mp3","time_start":76.4,"time_end":79.75},{"position":23,"content":"What is your favorite color?","audio_url":"https://dailydictation.com/upload/general-english/49-questions-and-answers-2019-03-29-10-19-31/23.mp3","time_start":81.4,"time_end":83.3},{"position":24,"content":"My favorite color is blue.","audio_url":"https://dailydictation.com/upload/general-english/49-questions-and-answers-2019-03-29-10-19-31/24.mp3","time_start":84.5,"time_end":86.6},{"position":25,"content":"Is your father home?","audio_url":"https://dailydictation.com/upload/general-english/49-questions-and-answers-2019-03-29-10-19-31/25.mp3","time_start":88.2,"time_end":89.5},{"position":26,"content":"Yes, just a minute, I will get him for you.","audio_url":"https://dailydictation.com/upload/general-english/49-questions-and-answers-2019-03-29-10-19-31/26.mp3","time_start":90.2,"time_end":92.9},{"position":27,"content":"May I help you?","audio_url":"https://dailydictation.com/upload/general-english/49-questions-and-answers-2019-03-29-10-19-31/27.mp3","time_start":94.5,"time_end":95.67},{"position":28,"content":"Yes, I am looking for the shoe department.","audio_url":"https://dailydictation.com/upload/general-english/49-questions-and-answers-2019-03-29-10-19-31/28.mp3","time_start":96.1,"time_end":98.83}]}