{"id":"es-416","language":"spanish","category_slug":"spanish-intermediate","category_name":"Spanish Listening - Intermediate","position":416,"title":"416. ¿Cuál es tu ciudad natal?","subtitle":"Manuel / Cuba","level":"Intermediate Spanish","parts":3,"url":"https://www.spanishlistening.org/content/416-manu-cuba-ciudadnatal.html","audio_url":"","youtube_video_id":"","vimeo_video_id":"212425400","video_url":"https://player.vimeo.com/video/212425400","details_cached_at":"2026-06-29T13:55:34","challenges":[{"position":1,"content":"Hola, mi nombre es Manuel, soy cubano.","audio_url":"","time_start":null,"time_end":null},{"position":2,"content":"Nací en Manzanillo, una ciudad costera de la parte oriental de Cuba. Es una ciudad muy bonita, la gente es muy amable, muy solidaria.","audio_url":"","time_start":null,"time_end":null},{"position":3,"content":"Eh, bueno pues, nada, los invito a que si un día van a Cuba, se lleguen a Manzanillo.","audio_url":"","time_start":null,"time_end":null}]}