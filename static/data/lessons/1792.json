:11.15},{"position":6,"content":"Is it possible to get a room with a city view?","audio_url":"https://dailydictation.com/upload/toeic/conversation-251-2024-11-03-20-03-37/6.mp3","time_start":11.15,"time_end":13.75},{"position":7,"content":"I can arrange that.","audio_url":"https://dailydictation.com/upload/toeic/conversation-251-2024-11-03-20-03-37/7.mp3","time_start":13.75,"time_end":15.23},{"position":8,"content":"We have a room on the tenth floor with a nice view of downtown.","audio_url":"https://dailydictation.com/upload/toeic/conversation-251-2024-11-03-20-03-37/8.mp3","time_start":15.23,"time_end":18.52},{"position":9,"content":"Will that work?","audio_url":"https://dailydictation.com/upload/toeic/conversation-251-2024-11-03-20-03-37/9.mp3","time_start":18.52,"time_end":19.52},{"position":10,"content":"Sounds perfect.","audio_url":"https://dailydictation.com/upload/toeic/conversation-251-2024-11-03-20-03-37/10.mp3","time_start":19.52,"time_end":20.75},{"position":11,"content":"What's the Wi-Fi situation here?","audio_url":"https://dailydictation.com/upload/toeic/conversation-251-2024-11-03-20-03-37/11.mp3","time_start":20.75,"time_end":23.08},{"position":12,"content":"We offer free high-speed Wi-Fi.","audio_url":"https://dailydictation.com/upload/toeic/conversation-251-2024-11-03-20-03-37/12.mp3","time_start":23.08,"time_end":25.47},{"position":13,"content":"Just use your room number to connect.","audio_url":"https://dailydictation.com/upload/toeic/conversation-251-2024-11-03-20-03-37/13.mp3","time_start":25.47,"time_end":27.31},{"position":14,"content":"If you're all set, I'll just need an ID and credit card to complete your check-in.","audio_url":"https://dailydictation.com/upload/toeic/conversation-251-2024-11-03-20-03-37/14.mp3","time_start":27.31,"time_end":31.57}]}