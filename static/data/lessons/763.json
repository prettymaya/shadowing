ing/ielts-cambridge-10-test-4-part-1-2023-06-16-15-47-56/40.mp3","time_start":115.48,"time_end":120.08},{"position":41,"content":"With all the weather damage, the glass in the door has cracked and I'd need that fixing...","audio_url":"https://dailydictation.com/upload/ielts-listening/ielts-cambridge-10-test-4-part-1-2023-06-16-15-47-56/41.mp3","time_start":120.08,"time_end":125.79},{"position":42,"content":"I presume you mean replacing?","audio_url":"https://dailydictation.com/upload/ielts-listening/ielts-cambridge-10-test-4-part-1-2023-06-16-15-47-56/42.mp3","time_start":125.79,"time_end":128.11},{"position":43,"content":"Oh, yes. And as soon as possible...","audio_url":"https://dailydictation.com/upload/ielts-listening/ielts-cambridge-10-test-4-part-1-2023-06-16-15-47-56/43.mp3","time_start":128.25,"time_end":130.96},{"position":44,"content":"What I'll do is come round tomorrow morning and do that immediately.","audio_url":"https://dailydictation.com/upload/ielts-listening/ielts-cambridge-10-test-4-part-1-2023-06-16-15-47-56/44.mp3","time_start":131.25,"time_end":134.5},{"position":45,"content":"Oh, thank you so much.","audio_url":"https://dailydictation.com/upload/ielts-listening/ielts-cambridge-10-test-4-part-1-2023-06-16-15-47-56/45.mp3","time_start":134.5,"time_end":136.27},{"position":46,"content":"The other things aren't so urgent but...","audio_url":"https://dailydictation.com/upload/ielts-listening/ielts-cambridge-10-test-4-part-1-2023-06-16-15-47-56/46.mp3","time_start":136.27,"time_end":139.27},{"position":47,"content":"Now, I'll make a note of everything you want doing.","audio_url":"https://dailydictation.com/upload/ielts-listening/ielts-cambridge-10-test-4-part-1-2023-06-16-15-47-56/47-2025-03-22-15-55-34.mp3","time_start":139.15,"time_end":142.28},{"position":48,"content":"Well, in the kitchen I'd like some painting doing.","audio_url":"https://dailydictation.com/upload/ielts-listening/ielts-cambridge-10-test-4-part-1-2023-06-16-15-47-56/48.mp3","tim