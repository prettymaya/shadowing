{"id":442,"category_slug":"english-conversations","category_name":"Conversations","position":44,"title":"44. A Less Formal Call","subtitle":"","level":"A2","parts":7,"url":"https://dailydictation.com/exercises/english-conversations/44-a-less-formal-call.442/listen-and-type","audio_url":"https://dailydictation.com/upload/english-conversations/44-a-less-formal-call-2022-03-07-21-19-50/0-44-a-less-formal-call.mp3","transcript":"Good afternoon, Scott and Smith. May I help you?\nMay I speak to Mr. Scott or Mr. Smith, please?\nI'm sorry, they aren't here right now. Who's calling, please?\nGeorge Martin.\nIs there any message I can take, Mr. Martin?\nNo, I'll call back later.\nThank you for calling Scott and Smith.","youtube_video_id":"","details_cached_at":"2026-06-15T20:48:45","challenges":[{"position":1,"content":"Good afternoon, Scott and Smith. May I help you?","audio_url":"https://dailydictation.com/upload/english-conversations/44-a-less-formal-call-2022-03-07-21-19-50/1.mp3","time_start":3.92,"time_end":6.63},{"position":2,"content":"May I speak to Mr. Scott or Mr. Smith, please?","audio_url":"https://dailydictation.com/upload/english-conversations/44-a-less-formal-call-2022-03-07-21-19-50/2.mp3","time_start":6.75,"time_end":9.79},{"position":3,"content":"I'm sorry, they aren't here right now. Who's calling, please?","audio_url":"https://dailydictation.com/upload/english-conversations/44-a-less-formal-call-2022-03-07-21-19-50/3.mp3","time_start":9.79,"time_end":12.95},{"position":4,"content":"George Martin.","audio_url":"https://dailydictation.com/upload/english-conversations/44-a-less-formal-call-2022-03-07-21-19-50/4.mp3","time_start":13.01,"time_end":14.15},{"position":5,"content":"Is there any message I can take, Mr. Martin?","audio_url":"https://dailydictation.com/upload/english-conversations/44-a-less-formal-call-2022-03-07-21-19-50/5.mp3","time_start":14.27,"time_end":16.43},{"position":6,"content":"No, I'll call back later.","audio_url":"https://dailydictation.com/upload/english-conversations/44-a-less-formal-call-2022-03-07-21-19-50/6.mp3","time_start":16.43,"time_end":18.43},{"position":7,"content":"Thank you for calling Scott and Smith.","audio_url":"https://dailydictation.com/upload/english-conversations/44-a-less-formal-call-2022-03-07-21-19-50/7.mp3","time_start":18.43,"time_end":20.28}]}